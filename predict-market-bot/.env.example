# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to "live" only when you are ready to trade real money.
TRADING_MODE=paper

# ── Polymarket ─────────────────────────────────────────────────────────────────
# TODO: Replace with real credentials from https://polymarket.com/
POLYMARKET_API_KEY=your_polymarket_api_key_here
POLYMARKET_API_SECRET=your_polymarket_api_secret_here
POLYMARKET_PRIVATE_KEY=your_eth_private_key_here
POLYMARKET_BASE_URL=https://clob.polymarket.com

# ── Kalshi ────────────────────────────────────────────────────────────────────
# TODO: Replace with real credentials from https://kalshi.com/
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_API_SECRET=your_kalshi_api_secret_here
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2
KALSHI_DEMO_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# ── Research ──────────────────────────────────────────────────────────────────
# Optional: enriches research pipeline
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NEWS_API_KEY=your_news_api_key_here

# ── Risk limits ───────────────────────────────────────────────────────────────
MAX_BANKROLL_FRACTION=0.05       # max fraction of bankroll per trade
MAX_OPEN_POSITIONS=10
MIN_EDGE_THRESHOLD=0.03          # minimum edge (our prob - market prob) to trade
KELLY_FRACTION=0.25              # fractional Kelly (0.25 = quarter-Kelly)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=data/logs/bot.log
